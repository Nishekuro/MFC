Далее определим поведение целевой функции вокруг точки экстремума: определим Гессиан:

$ bold(G) = mat(
  2, 0, 0;
  0, 2, 0;
  0, 0, 2
)\
F_(bold(G))(bold(Delta x)) = (bold(Delta x))^T bold(G)(bold(x)) (bold(Delta x)) = 2 Delta x_1^2 + 2 Delta x_2^2 + 2 Delta x_3^2 $

Положительная определенность матрицы Гессе (все коэффициенты при квадратах положительны) гарантирует, что квадратичная форма строго положительна для любого ненулевого $bold(Delta x)$. Таким образом, достаточные условия минимума выполнены.

= Решение численным методом

Использование функции `fmincon` для решения задачи представлено в @lsg1[листинге]. Результаты работы функции представлены на @img3[рисунке]. Линии равного уровня суммарной себестоимости $Q$ и линии ограничений представлены на @img1[рисунке].

#figure(
  ```matlab
  clear; clc;

  % Параметы
  a = [10; 10; 10];
  d = [1; 1; 1];
  b = [10000; 1000];
  t = [0.1 0.5 0];

  % Целевая функция
  Q = @(x) sum((a + d.*x(:)).*x(:));

  % Метод Лагранжа
  [x,Q_min] = lagrange(Q, a, d, b, t);
  disp('*Резултаты работы функции метода Лагранжа*');
  lab6_print(x, Q_min);

  % fmincon
  options = optimoptions('fmincon', 'Display','off');
  [x, Q_min] = fmincon(Q, [0;0;0], [], [], [1,1,1; t], b, [0;0;0], [], [], options);
  disp('*Резултаты работы функции fmincon*');
  lab6_print(x, Q_min);

  % График
  lab6_plot(Q, b, t, x);

  function [x_opt, Q_min] = lagrange(Q, a, d, b, t)
      % Символьные переменные
      x = sym('x', [3,1], 'real');
      lambda = sym('lambda', [2,1], 'real');
      delta = sym('delta', [3,1], 'real');

      % Функция Лагранжа
      L = Q(x) + lambda(1)*(b(1) - sum(x)) + lambda(2)*(b(2) - t*x)

      % Производные
      grad = gradient(L, [x; lambda]) == 0

      % Решение
      sol = solve(grad, [x; lambda]);

      % Матрица Гессе
      G = hessian(L, x)
      Fg = delta' * G * delta

      % Вывод результатов
      x_opt = double([sol.x1; sol.x2; sol.x3]);
      Q_min = Q(x_opt);
  end

  function [] = lab6_plot(Q, b, t, x)
      % Сетка
      [X1, X2] = meshgrid(linspace(0, b(2)/t(1), 100), ...
                          linspace(0, b(1)-x(3), 100));

      % Вычисляем Q через arrayfun (сохраняет x(:))
      Q_vals = arrayfun(@(x1,x2) Q([x1; x2; x(3)]), X1, X2);

      % График
      levels = [linspace(0, 1.5*10^8, 17)];
      contour(X1, X2, Q_vals, levels, 'ShowText','on');
      grid on; hold on;
      xlabel('x_1'); ylabel('x_2');

      % Ограничения
      plot([0, b(1)-x(3)],[b(1)-x(3), 0])
      plot([0, b(2)/t(1)],[b(2)/t(2), 0])

      % Оптимум
      plot(x(1), x(2),'Marker','o', 'MarkerSize',10)
  end

  function [] = lab6_print(x, Q_min)
      fprintf('Минимальная себестоимость выпуска (Q): | %.2f\n', Q_min);
      disp(   '----------------------------------------------------');
      fprintf('Оптимальный объемы выпуска x1:         | %.2f\n', x(1));
      fprintf('Оптимальный объемы выпуска x2:         | %.2f\n', x(2));
      fprintf('Оптимальный объемы выпуска x3:         | %.2f\n', x(3));
       disp(   '----------------------------------------------------');
  end

